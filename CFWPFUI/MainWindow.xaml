<Window x:Class="CFWPFUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CFWPFUI"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" VerticalAlignment="Top" Margin="0,0,0,8">
            <TextBox x:Name="SyncRootPathBox" Width="420" Margin="0,0,8,0" />
            <Button x:Name="BtnRegister" Content="Register Sync Root" Width="140" Click="BtnRegister_Click" />
            <Button x:Name="BtnRefresh" Content="Refresh" Width="80" Margin="8,0,0,0" Click="BtnRefresh_Click" />
        </StackPanel>

        <ListView x:Name="FilesList" Grid.Row="1" AllowDrop="True" Drop="FilesList_Drop" DragOver="FilesList_DragOver">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Name" Width="300" DisplayMemberBinding="{Binding Name}" />
                    <GridViewColumn Header="Size" Width="100" DisplayMemberBinding="{Binding SizeDisplay}" />
                    <GridViewColumn Header="Status" Width="120" DisplayMemberBinding="{Binding Status}" />
                    <GridViewColumn Header="Path" Width="300" DisplayMemberBinding="{Binding Path}" />
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Left" Margin="0,8,0,0">
            <Button x:Name="BtnCreatePlaceholder" Content="Create Placeholder" Width="140" Click="BtnCreatePlaceholder_Click" />
            <Button x:Name="BtnHydrate" Content="Trigger Hydration" Width="140" Margin="8,0,0,0" Click="BtnHydrate_Click" />
            <Button x:Name="BtnNotify" Content="Notify State" Width="120" Margin="8,0,0,0" Click="BtnNotify_Click" />
            <TextBlock x:Name="StatusBlock" Margin="16,4,0,0" VerticalAlignment="Center" />
        </StackPanel>
    </Grid>
</Window>
