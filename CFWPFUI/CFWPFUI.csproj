<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <!-- Ensure we build/run for x64 so native x64 DLLs are loadable -->
    <PlatformTarget>x64</PlatformTarget>
  </PropertyGroup>

  <!-- Copy native cfAPINativeEngine.dll from possible native build output locations into the WPF output -->
  <Target Name="CopyNativeDll" AfterTargets="Build">
    <ItemGroup>
      <NativeDllPaths Include="..\cfAPINativeEngine\$(Configuration)\$(Platform)\cfAPINativeEngine.dll" />
      <NativeDllPaths Include="..\cfAPINativeEngine\$(Configuration)\cfAPINativeEngine.dll" />
      <NativeDllPaths Include="..\cfAPINativeEngine\bin\$(Configuration)\cfAPINativeEngine.dll" />
      <NativeDllPaths Include="..\cfAPINativeEngine\Debug\cfAPINativeEngine.dll" />
      <NativeDllPaths Include="..\cfAPINativeEngine\Release\cfAPINativeEngine.dll" />
    </ItemGroup>
    <Copy SourceFiles="@(NativeDllPaths)" DestinationFolder="$(OutputPath)" SkipUnchangedFiles="true" ContinueOnError="true" />
  </Target>

</Project>
